# --- Server ---
PORT=4000
WEB_ORIGIN=http://localhost:5173

# --- Microsoft Graph (Azure AD app registration) ---
# Single-tenant app, redirect URI must include http://localhost:4000/auth/callback
MS_TENANT_ID=
MS_CLIENT_ID=
# For a public/desktop client leave secret blank. For a web/confidential client paste it here.
MS_CLIENT_SECRET=

# --- Jira Cloud ---
# Example: https://yourcompany.atlassian.net
JIRA_BASE_URL=
JIRA_EMAIL=
# Personal API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=
